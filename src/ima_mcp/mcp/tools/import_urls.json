{
  "name": "import_urls",
  "description": "添加网页到 IMA 知识库",
  "arguments": {
    "type": "object",
    "properties": {
      "knowledge_base_id": {
        "type": "string",
        "description": "知识库 ID"
      },
      "urls": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "要添加的网页 URL 列表"
      },
      "folder_id": {
        "type": "string",
        "description": "文件夹 ID，可选"
      }
    },
    "required": ["knowledge_base_id", "urls"]
  }
}
